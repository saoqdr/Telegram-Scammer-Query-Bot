# Telegram
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELETHON_API_ID=12345678
TELETHON_API_HASH=YOUR_TELEGRAM_API_HASH
ADMIN_ID=123456789
LOG_CHANNEL_ID=-1001234567890
BOT_USERNAME=your_bot_username

# Web
FLASK_SECRET_KEY=change_me_to_a_random_secret
WEB_BASE_URL=https://your-domain.example
PUBLIC_BASE_URL=https://your-domain.example
APP_PORT=1012
CHATLOG_TOKEN_TTL_SEC=900
CHATLOG_FEATURE_DEFAULT=1
WEB_VERIFY_ENABLED=1
WEB_REQUIRED_CHANNEL=@your_channel
WEB_REQUIRED_CHANNEL_URL=https://t.me/your_channel

# Database / data files
DATABASE_FILE=history.db
REPORTS_FILE=reports.json
CHANNELS_FILE=channels.json
WEB_TELETHON_SESSION_FILE=web_scan.session

# OKPay (optional)
OKPAY_ID=10000
OKPAY_TOKEN=YOUR_OKPAY_TOKEN
CALLBACK_BASE_URL=https://your-domain.example
WEBHOOK_PORT=1010
WEBHOOK_PUBLIC_PORT=1010

# Deploy
TZ=Asia/Shanghai
HOST_IP=0.0.0.0
PANEL_APP_PORT_HTTP=1012
PYTHON_VERSION=3.10-slim
CONTAINER_NAME=zpf-web
CODE_DIR=/path/to/project
